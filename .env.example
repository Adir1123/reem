# =============================================================================
# Reem Carousel Dashboard — environment variables
# Copy to `.env` and fill in. NEVER commit `.env`.
# =============================================================================

# -- Supabase ----------------------------------------------------------------
# Server-side (Trigger.dev tasks, Next.js route handlers, server actions)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# Client-side (Next.js — must mirror the server values)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -- Trigger.dev v4 ----------------------------------------------------------
TRIGGER_SECRET_KEY=tr_dev_xxx
TRIGGER_PROJECT_ID=proj_xxx

# -- Site / auth -------------------------------------------------------------
# Used for magic-link redirect URLs. Vercel preview URLs override this at runtime.
SITE_URL=http://localhost:3000

# -- Encryption --------------------------------------------------------------
# 32-byte base64 key. Generate once with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Stored only in Trigger.dev env + 1Password. Loss = all client API keys lost.
MASTER_ENCRYPTION_KEY=

# -- Pipeline secrets (DEV only) ---------------------------------------------
# In production these come from app_settings (encrypted, per-client).
# Local dev can fall back to .env so you can run the Python pipeline without
# wiring the /settings UI first.
ANTHROPIC_API_KEY=
APIFY_TOKEN=

# -- Single-tenant defaults --------------------------------------------------
# The seeded client UUID. Matches packages/db/supabase/migrations/0002_seed_topics.sql.
CLIENT_ID=2ba3a610-1753-427f-a95c-c91fcbc98a04
